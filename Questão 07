#include <stdio.h> // Inclusão da biblioteca padrão de entrada e saída

int main() {
    // Declaração das variáveis para armazenar o número e os seus resultados
    int numero;
    int antecessor;
    int sucessor;

    // Entrada de dados: lê o número inteiro digitado pelo usuário
    printf("Digite um numero inteiro: ");
    scanf("%d", &numero);

    // Processamento: realiza os cálculos matemáticos baseados no número informado
    antecessor = numero - 1; // O antecessor é o número subtraído de uma unidade
    sucessor = numero + 1;   // O sucessor é o número somado a uma unidade

    // Exibição dos resultados (Comandos de Saída)
    printf("\n=== RESULTADOS ===\n");
    printf("Numero digitado: %d\n", numero);
    printf("Antecessor:      %d\n", antecessor);
    printf("Sucessor:        %d\n", sucessor);

    return 0; // Indica que o programa foi executado com sucesso
}
