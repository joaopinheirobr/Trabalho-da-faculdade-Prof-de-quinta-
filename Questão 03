#include <stdio.h> //Inclusao da biblioteca padrao de entrada e saida

int main (){
	//Declaracao das variaveis para armazenar os dois numeros inteiros digitados
	//utilizando tipo float para permitir que o programa opere tanto com numeros inteiros quanto decimais
	float num1, num2;
	
	//Declaracao das variaveis para armazenar os resultados de cada operacao matematica
	float soma, subtracao, multiplicacao, divisao;
	
	
	//Entrada de dados: leitura do primeiro numero
	printf("Digite o primeiro numero inteiro: ");
	scanf("%f", &num1);
	
	//Entrada de dados: leitura do segundo numero 
	printf("Digite o segundo numero inteiro: ");
	scanf("%f", &num2);
	
	//Processamento de dados
	soma = num1 + num2;				//Operador de soma
	subtracao = num1 - num2;		//Operador de subtracao
	multiplicacao = num1 * num2;	//Operador de multiplicacao
	divisao = num1 / num2;			//Operador de divisao
	
	// Exibicao dos resultados formatados na tela
	printf ("\n ====RESULTADOS==== \n");
	
	//O modificador %.2f eh empregado para limitar a exibicao a apenas duas casas decimais
	printf ("Soma: %.2f\n", soma);
	printf ("Subtracao: %.2f\n", subtracao);
	printf ("Multiplicacao: %.2f\n", multiplicacao);
	printf ("Divisao: %.2f\n", divisao);
	
	return 0; //Sinaliza para o sistema operacional que o programa finalizou
}
